#!/bin/sh
# Pre-commit hook to block commits if Task8/script.js has console.log

FILE="Task8/script.js"

# Check if file exists
if [ ! -f "$FILE" ]; then
  echo "$FILE not found. Skipping pre-commit check."
  exit 0
fi

# Search for console.log
if grep -q "console.log" "$FILE"; then
  echo "Error: Remove console.log statements from $FILE before committing!"
  exit 1  # Block commit
fi

echo "$FILE passed pre-commit checks! Commit allowed."
exit 0  # Allow commit